# Copy to .env and fill in. .env is gitignored.

# --- Required: voice loop services ---
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=

# --- Voice loop (optional overrides) ---
# VOICE_LOOP_MODEL=gpt-5.4-mini
# VOICE_LOOP_REASONING_EFFORT=none
# CARTESIA_VOICE_ID=
# SPEECH_PROVIDER=deepgram-cartesia
# VOICE_PROVIDER=openai

# Optional feature decorators, applied in order. The built-in Nemo bridge
# consumes normalized OpenShell JSONL events and emits normalized telemetry.
# AGENT_VOICE_FEATURES=openshell-events,nemo-telemetry
# OPENSHELL_EVENTS_FILE=/tmp/agent-voice-openshell-events.jsonl
# AGENT_VOICE_TELEMETRY_FILE=/tmp/agent-voice-telemetry.jsonl
# AGENT_VOICE_SKIP_DOTENV=1  # CI/evals: use exported environment only
# AGENT_LOOP_MODE_OVERRIDE=mock  # final precedence-safe CI/eval override

# --- Agent loop backend (optional; defaults to the mock) ---
# AGENT_LOOP_MODE=mock            # mock | rest | openai | mcp | hermes | nemohermes | deepagents | openclaw
# AGENT_LOOP_TIMEOUT_SECS=60

# mock
# AGENT_LOOP_MOCK_DELAY_SECS=0.2
# AGENT_LOOP_MOCK_RESULT=ZEBRA-4417

# rest
# AGENT_LOOP_REST_URL=http://localhost:8080/run

# openai-compatible
# AGENT_LOOP_OPENAI_BASE_URL=http://localhost:11434/v1
# AGENT_LOOP_OPENAI_MODEL=hermes-agent
# AGENT_LOOP_OPENAI_API_KEY=
# AGENT_LOOP_REASONING_EFFORT=high

# mcp
# AGENT_LOOP_MCP_TRANSPORT=stdio  # stdio | sse | http
# AGENT_LOOP_MCP_COMMAND=python
# AGENT_LOOP_MCP_ARGS=["server.py"]
# AGENT_LOOP_MCP_URL=
# AGENT_LOOP_MCP_TOOL=run_agent

# Hermes API server
# AGENT_LOOP_MODE=hermes
# AGENT_LOOP_HERMES_BASE_URL=http://127.0.0.1:8765
# AGENT_LOOP_HERMES_API_KEY=
# AGENT_LOOP_HERMES_MODEL=hermes-agent
# AGENT_LOOP_HERMES_SESSION_KEY=agent-voice-bot

# NemoHermes sandbox OpenAI-compatible API
# AGENT_LOOP_MODE=nemohermes
# AGENT_LOOP_NEMOHERMES_BASE_URL=http://127.0.0.1:8642/v1
# AGENT_LOOP_NEMOHERMES_MODEL=hermes-agent
# AGENT_LOOP_NEMOHERMES_API_KEY=

# NemoClaw + LangChain Deep Agents Code (headless dcode task)
# AGENT_LOOP_MODE=deepagents
# AGENT_LOOP_DEEPAGENTS_COMMAND=nemoclaw
# AGENT_LOOP_DEEPAGENTS_SANDBOX=nd

# OpenClaw Gateway
# AGENT_LOOP_MODE=openclaw
# AGENT_LOOP_OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# AGENT_LOOP_OPENCLAW_TOKEN=
# AGENT_LOOP_OPENCLAW_PASSWORD=
# AGENT_LOOP_OPENCLAW_SESSION_KEY=agent:main:main
