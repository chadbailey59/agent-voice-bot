# Copy to .env and fill in. .env is gitignored.

# --- Required: voice loop services ---
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=

# --- Voice loop (optional overrides) ---
# VOICE_LOOP_MODEL=gpt-5.4-mini
# VOICE_LOOP_REASONING_EFFORT=none
# CARTESIA_VOICE_ID=

# --- Agent loop backend (optional; defaults to the mock) ---
# AGENT_LOOP_MODE=mock            # mock | rest | openai | mcp
# AGENT_LOOP_TIMEOUT_SECS=60

# mock
# AGENT_LOOP_MOCK_DELAY_SECS=0.2
# AGENT_LOOP_MOCK_RESULT=ZEBRA-4417

# rest
# AGENT_LOOP_REST_URL=http://localhost:8080/run

# openai-compatible
# AGENT_LOOP_OPENAI_BASE_URL=http://localhost:11434/v1
# AGENT_LOOP_OPENAI_MODEL=hermes-agent
# AGENT_LOOP_OPENAI_API_KEY=
# AGENT_LOOP_REASONING_EFFORT=high

# mcp
# AGENT_LOOP_MCP_TRANSPORT=stdio  # stdio | sse | http
# AGENT_LOOP_MCP_COMMAND=python
# AGENT_LOOP_MCP_ARGS=["server.py"]
# AGENT_LOOP_MCP_URL=
# AGENT_LOOP_MCP_TOOL=run_agent
